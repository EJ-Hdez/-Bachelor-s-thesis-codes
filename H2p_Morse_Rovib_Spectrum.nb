       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"With", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"dE", "=", 
              RowBox[{
               RowBox[{"ErotAbs", "[", 
                RowBox[{"J", "+", "2"}], "]"}], "-", 
               RowBox[{"ErotAbs", "[", "J", "]"}]}]}], ",", 
             RowBox[{"inten", "=", 
              RowBox[{"IrotRam", "[", "J", "]"}]}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"dE", "*", "EhToCm1"}], ",", 
             RowBox[{"If", "[", 
              RowBox[{"useIntensity", ",", "inten", ",", "1.0"}], "]"}]}], 
            "}"}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"J", ",", "0", ",", 
           RowBox[{"Max", "[", 
            RowBox[{"2", ",", 
             RowBox[{
              RowBox[{"Jmax", "[", "0", "]"}], "-", "2"}]}], "]"}]}], "}"}]}],
         "]"}], ",", 
       RowBox[{"stickMode", "==", "\"\<rovib_dipole\>\""}], ",", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"With", "[", 
