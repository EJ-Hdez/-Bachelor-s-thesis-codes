       RowBox[{"J", "+", "1"}], ")"}], " ", 
      RowBox[{"boltz", "[", "J", "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"IrotRam", "[", "J_", "]"}], ":=", 
