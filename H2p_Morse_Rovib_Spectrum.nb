       RowBox[{"-", "E"}], "/", "kT"}], ")"}]}], "*)"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Intensidad", " ", "modelo", " ", 
      RowBox[{"(", "pedag\[OAcute]gica", ")"}]}], ":", "rot_dipole", ":", 
     RowBox[{"I", "\[Proportional]", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"2", "J"}], "+", "1"}], ")"}], 
       RowBox[{"(", 
        RowBox[{"J", "+", "1"}], ")"}], " ", "exp", 
       RowBox[{"(", 
