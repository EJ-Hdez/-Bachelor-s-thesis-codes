       RowBox[{"stickMode", "==", "\"\<rot_dipole\>\""}], ",", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"With", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"dE", "=", 
              RowBox[{
               RowBox[{"ErotAbs", "[", 
                RowBox[{"J", "+", "1"}], "]"}], "-", 
               RowBox[{"ErotAbs", "[", "J", "]"}]}]}], ",", 
             RowBox[{"inten", "=", 
              RowBox[{"IrotDip", "[", "J", "]"}]}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"dE", "*", "EhToCm1"}], ",", 
             RowBox[{"If", "[", 
              RowBox[{"useIntensity", ",", "inten", ",", "1.0"}], "]"}]}], 
            "}"}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"J", ",", "0", ",", 
           RowBox[{"Max", "[", 
