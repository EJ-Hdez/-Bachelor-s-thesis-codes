            RowBox[{"2", "J"}], "+", "1"}], ")"}], " ", "exp", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", "EJ"}], "/", "kT"}], ")"}], " ", 
          RowBox[{"(", "simplificado", ")"}]}]}]}]}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"IrotDip", "[", "J_", "]"}], ":=", 
     RowBox[{
