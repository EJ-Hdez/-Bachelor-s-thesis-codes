     RowBox[{"Exp", "[", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{"ErotAbs", "[", "J", "]"}]}], "/", 
       RowBox[{"(", 
        RowBox[{"kBEhK", " ", "Tkelvin"}], ")"}]}], "]"}]}], ";"}], "  ", 
   RowBox[{"(*", 
