          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", "EJ"}], "/", "kT"}], ")"}], " ", 
          RowBox[{"(", 
           RowBox[{"forma", " ", "simple"}], ")"}], " ", "rovib_dipole"}]}], ":", 
        RowBox[{"I", "\[Proportional]", 
         RowBox[{
          RowBox[{"(", 
