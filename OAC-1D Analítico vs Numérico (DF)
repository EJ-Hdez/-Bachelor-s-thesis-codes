outDir = "/home/ej-hdez/Descargas/OAC";

If[! DirectoryQ[outDir], 
  CreateDirectory[outDir, CreateIntermediateDirectories -> True]];

Export[FileNameJoin[{outDir, "OAC_densidades_grid.pdf"}], densGrid];
Export[FileNameJoin[{outDir, "OAC_potencial_autofunciones.pdf"}], 
  plotFloat];
Export[FileNameJoin[{outDir, "OAC_tabla_energias.pdf"}], enerTable];
Export[FileNameJoin[{outDir, "OAC_ortonormalidad.pdf"}], 
  MatrixForm[orthoMat]];

