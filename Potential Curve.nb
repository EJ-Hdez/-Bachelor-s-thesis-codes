Cell[CellGroupData[{

Cell["Sobre los encabezados:", "Subsubsection",
 CellChangeTimes->{{3.9639449056499825`*^9, 
  3.963944924520115*^9}},ExpressionUUID->"7569c71b-924c-6449-9358-\
9899872d6fa4"],

Cell[TextData[{
 "\[LeftBracketingBar]\[CapitalDelta]\[RightBracketingBar] ",
 Cell[BoxData[
  FormBox["\[Rule]", TraditionalForm]],ExpressionUUID->
  "3fe760b1-4704-154a-adfa-ed68a7673b02"],
 " Media absoluta de la diferencia ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[LeftBracketingBar]", 
    RowBox[{
     SubscriptBox["E", "tot"], "-", 
     RowBox[{"E", "(", "x", ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "52689008-d609-f84b-9ab4-5d57585cf3af"],
 "\[RightBracketingBar]. Da una idea del promedio de la discrepancia en las \
unidades de energ\[IAcute]a de tu c\[AAcute]lculo.\nmax\[LeftBracketingBar]\
\[CapitalDelta]\[RightBracketingBar]",
 Cell[BoxData[
  FormBox["\[Rule]", TraditionalForm]],ExpressionUUID->
  "0009be78-7bd9-d346-b42f-3d9649d867d5"],
 " Valor m\[AAcute]ximo absoluto de la diferencia en el intervalo de x que se \
est\[AAcute] graficando.\n\[LeftAngleBracket]%\[RightAngleBracket] ",
 Cell[BoxData[
  FormBox["\[Rule]", TraditionalForm]],ExpressionUUID->
  "5ed12d99-2c89-4e4a-8608-d06536fe476a"],
 " porcentaje promedio de la desviaci\[OAcute]n relativa respecto a E(x). Es \
decir, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"\[LeftBracketingBar]", 
      RowBox[{
       SubscriptBox["E", "tot"], "-", 
       RowBox[{"E", "(", "x", ")"}]}], "\[RightBracketingBar]"}], 
     RowBox[{"\[LeftBracketingBar]", 
      RowBox[{"E", "(", "x", ")"}], "\[RightBracketingBar]"}]], "\[Times]"}], 
   TraditionalForm]],ExpressionUUID->"f5f7ea51-35e8-8442-ba79-17f2dcd8c1c8"],
 "100 promediado sobre todos los puntos.\nmax%",
 Cell[BoxData[
  FormBox[
   RowBox[{" ", "\[Rule]"}], TraditionalForm]],ExpressionUUID->
  "6df90c0c-5af8-d84a-b920-cad71ac7e333"],
 " porcentaje relativo m\[AAcute]ximo de desviaci\[OAcute]n en el rango.\nLo \
anterior sirve para cuantificar qu\[EAcute] tan bien coinciden ambas curvas \
en escala absoluta y relativa; e.g. si \[LeftAngleBracket]%\
\[RightAngleBracket]  es peque\[NTilde]o, ambas son pr\[AAcute]cticamente \
indistinguibles en promedio."
}], "Text",
 CellChangeTimes->{{3.9639449418531475`*^9, 3.9639449900774193`*^9}, {
  3.9639450332572308`*^9, 3.963945374311468*^9}, {3.964017906577198*^9, 
  3.96401790788101*^9}},ExpressionUUID->"1aafed4e-c00d-bf4f-a999-\
fda3a1f61e09"]
}, Open  ]],

