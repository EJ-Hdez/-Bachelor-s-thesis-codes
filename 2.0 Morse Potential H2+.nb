Cell[CellGroupData[{

Cell["Notas", "Subsubsection",
 CellChangeTimes->{{3.964618192364525*^9, 
  3.9646182000901127`*^9}},ExpressionUUID->"1b3910b7-ba34-e643-8027-\
9d6c10c82381"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["E", "TI"], "rel"], TraditionalForm], "errors" -> {}, 
     "input" -> "E_{\\text{rel}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5bc094fd-52db-594b-a882-a2e348d426a5"],
 " Es la energ\[IAcute]a relativa al m\[IAcute]nimo del potencial, medida en \
unidades at\[OAcute]micas (Hartree). Matem\[AAcute]ticamente corresponde al \
valor ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["E", "TI"], "\[Nu]"], TraditionalForm], "errors" -> {}, 
     "input" -> "E_{\\nu}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e5952ac6-c050-f844-8810-5c06559ddd78"],
 " que entrega la f\[OAcute]rmula de niveles vibracionales: ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["E", "TI"], "\[Nu]"], "\[LongEqual]", 
         SubscriptBox["\[Omega]", 
          StyleBox["e", "TI"]], 
         RowBox[{"(", 
           RowBox[{"\[Nu]", "+", "1", "/", "2"}], ")"}], "-", 
         FractionBox[
          SubsuperscriptBox["\[Omega]", 
           StyleBox["e", "TI"], "2"], 
          RowBox[{"4", 
            SubscriptBox[
             StyleBox["D", "TI"], 
             StyleBox["e", "TI"]]}]], 
         SuperscriptBox[
          RowBox[{"(", 
            RowBox[{"\[Nu]", "+", "1", "/", "2"}], ")"}], "2"]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "E_{\\nu}=\\omega_e (\\nu+1/2)-\\frac{\\omega_e^2}{4D_e}(\\nu+1/2)^2", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0027f081-0a5d-4947-bbc9-ea99ba380c5e"],
 ", i.e., es cu\[AAcute]nto \[OpenCurlyDoubleQuote]por arriba del fondo\
\[CloseCurlyDoubleQuote] del pozo est\[AAcute] colocado ese nivel \
vibracional. E.g. si el nivel base ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"(", 
         RowBox[{"\[Nu]", "\[LongEqual]", "0"}], ")"}], TraditionalForm], 
     "errors" -> {}, "input" -> "(\\nu=0)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5cd18c1f-d587-f347-931b-d2ad32ea6824"],
 " aparece con ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["E", "TI"], 
          RowBox[{
            StyleBox["r", "TI"], 
            StyleBox["e", "TI"], 
            StyleBox["l", "TI"]}]], "\[LongEqual]", "0.020", 
         StyleBox["E", "TI"], 
         StyleBox["h", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "E_{rel}=0.020 Eh", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "59dac51c-d0ce-8441-96c3-f28e60c1e616"],
 ", significa que el estado fundamental est\[AAcute] a esa altura sobre el \
fondo del pozo de Morse."
}], "Text",
 CellChangeTimes->{{3.964618202374542*^9, 3.9646183938373814`*^9}, {
  3.964618428219883*^9, 3.9646184394169807`*^9}, {3.964618495934473*^9, 
  3.964618569181818*^9}},ExpressionUUID->"e8d9bb1d-6bbc-f64a-9273-\
fd8fc2681011"],

Cell[TextData[{
 " ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["E", "TI"], "abs"], TraditionalForm], "errors" -> {}, 
     "input" -> "E_{\\text{abs}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f949dd14-fd60-e842-87af-5a53a435447b"],
 " es la energ\[IAcute]a absoluta total, tambi\[EAcute]n en Hartree, pero \
ahora incluyendo la posici\[OAcute]n del m\[IAcute]nimo real del potencial. (",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["E", "TI"], 
        RowBox[{
          StyleBox["m", "TI"], 
          StyleBox["i", "TI"], 
          StyleBox["n", "TI"], 
          StyleBox["r", "TI"], 
          StyleBox["e", "TI"], 
          StyleBox["a", "TI"], 
          StyleBox["l", "TI"]}]], TraditionalForm], "errors" -> {}, "input" -> 
     "E_{min real}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "62061d74-e2e9-c14f-b0bd-9f432a7736ad"],
 "):"
}], "Text",
 CellChangeTimes->{{3.964618659656639*^9, 
  3.9646186958777256`*^9}},ExpressionUUID->"7fc9ca61-f36d-3643-8689-\
c66a90db84e9"],

Cell[BoxData[
 TemplateBox[<|"boxes" -> FormBox[
     RowBox[{
       SubscriptBox[
        StyleBox["E", "TI"], 
        RowBox[{
          StyleBox["a", "TI"], 
          StyleBox["b", "TI"], 
          StyleBox["s", "TI"]}]], "\[LongEqual]", 
       SubscriptBox[
        StyleBox["E", "TI"], "min real"], "+", 
       SubscriptBox[
        StyleBox["E", "TI"], "\[Nu]"]}], TraditionalForm], "errors" -> {}, 
   "input" -> "E_{abs}=E_{\\text{min real}}+E_{\\nu}", "state" -> "Boxes"|>,
  "TeXAssistantTemplate"]], "Input",
 CellChangeTimes->{
  3.9646186988033237`*^9},ExpressionUUID->"9d8182ec-0b4b-ff40-98a5-\
86b6d607feec"],

Cell[TextData[{
 "Esta es la cantidad que se puede comparar directamente con la curva de \
potencial \[OpenCurlyDoubleQuote]real\[CloseCurlyDoubleQuote] ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{
          SubscriptBox[
           StyleBox["E", "TI"], 
           StyleBox["x", "TI"]], "(", 
          RowBox[{
            StyleBox["x", "TI"], ",", 
            SubscriptBox[
             StyleBox["Z", "TI"], 
             StyleBox["a", "TI"]], ",", 
            StyleBox["C", "TI"]}], ")"}], TraditionalForm], "errors" -> {}, 
      "input" -> "E_x (x,Z_a,C)", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], "."}], TraditionalForm]],ExpressionUUID->
  "20f1c941-de63-8e4e-a0d1-460ab9476f88"],
 "\nEs decir, si dibujas la curva roja (potencial real) y colocas estas l\
\[IAcute]neas horizontal en ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["E", "TI"], "abs"], TraditionalForm], "errors" -> {}, 
     "input" -> "E_{\\text{abs}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "04dace9a-1e69-eb4b-905d-1aaca4545180"],
 ", coinciden con los niveles de energ\[IAcute]a f\[IAcute]sica del sistema."
}], "Text",
 CellChangeTimes->{{3.964618730659687*^9, 
  3.9646188082739544`*^9}},ExpressionUUID->"67c683bc-7685-c046-9979-\
b59644c91c99"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Resumen", "Subsubsection",
 CellChangeTimes->{{3.9646188923592777`*^9, 
  3.9646188948546505`*^9}},ExpressionUUID->"039d728d-b053-9846-aa28-\
300fd264f709"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["E", "TI"], "rel"], TraditionalForm], "errors" -> {}, 
     "input" -> "E_{\\text{rel}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "bbcd025a-6bb6-7440-b81b-259b6f7bba9b"],
 " lo que predice el modelo del oscilador  de Morse para cada ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Nu]", TraditionalForm], "errors" -> {}, "input" -> 
     "\\nu", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "042f6989-b421-554e-ab28-bd7c2124b73a"],
 ", medido desde el fondo.\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["E", "TI"], "abs"], TraditionalForm], "errors" -> {}, 
     "input" -> "E_{\\text{abs}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1b012a5c-8cdb-5c4b-b8c9-7634f863b23a"],
 " la posici\[OAcute]n real del nivel dentro de la curva completa del \
potencial, listo para compararse con la gr\[AAcute]fica roja ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["E", "TI"], 
          StyleBox["x", "TI"]], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["x", "TI"], ",", 
             SubscriptBox[
              StyleBox["Z", "TI"], 
              StyleBox["a", "TI"]], ",", 
             StyleBox["C", "TI"]}], ")"}], "."}], TraditionalForm], 
     "errors" -> {}, "input" -> "E_x (x,Z_a,C).", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "57c8641c-e93f-a54e-905f-8054342be679"]
}], "Text",
 CellChangeTimes->{{3.964618898739609*^9, 3.964618987049917*^9}, {
  3.9646351219765453`*^9, 3.9646351312065773`*^9}, {3.9646351678533897`*^9, 
  3.964635173719513*^9}},ExpressionUUID->"ff5b45ea-9dad-b344-90c1-\
d0d46ebbf636"],

Cell["", "Text",
 CellChangeTimes->{{3.964618630310171*^9, 
  3.96461865022447*^9}},ExpressionUUID->"23556eda-008b-314f-8c3b-\
f55599ce6e41"]
}, Open  ]],

