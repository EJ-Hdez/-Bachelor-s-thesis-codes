         RowBox[{"Directive", "[", 
          RowBox[{
           RowBox[{"GrayLevel", "[", ".25", "]"}], ",", "Thin"}], "]"}]}], 
        "}"}]}], ",", 
      RowBox[{"ScalingFunctions", "->", 
       RowBox[{"{", 
        RowBox[{"\"\<Log\>\"", ",", "None"}], "}"}]}]}], "]"}]}], ";", 
   RowBox[{"pltNumLog", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"ListLinePlot", "[", 
       RowBox[{"tPts", ",", 
        RowBox[{"PlotRange", "->", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"v2Min", ",", "v2Max"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"0", ",", "1"}], "}"}]}], "}"}]}], ",", 
        RowBox[{"PlotStyle", "->", 
         RowBox[{"Directive", "[", 
          RowBox[{"numColor", ",", "Thin"}], "]"}]}], ",", 
        RowBox[{"PlotMarkers", "->", 
         RowBox[{"{", 
          RowBox[{"\"\<\[FilledCircle]\>\"", ",", "8"}], "}"}]}], ",", 
        RowBox[{"ScalingFunctions", "->", 
         RowBox[{"{", 
          RowBox[{"\"\<Log\>\"", ",", "None"}], "}"}]}]}], "]"}], ",", 
      RowBox[{"ListLinePlot", "[", 
       RowBox[{"rPts", ",", 
        RowBox[{"PlotRange", "->", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"v2Min", ",", "v2Max"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"0", ",", "1"}], "}"}]}], "}"}]}], ",", 
        RowBox[{"PlotStyle", "->", 
         RowBox[{"Directive", "[", 
          RowBox[{"numColor", ",", "Thin", ",", "Dashed"}], "]"}]}], ",", 
        RowBox[{"PlotMarkers", "->", 
         RowBox[{"{", 
          RowBox[{"\"\<\[EmptySquare]\>\"", ",", "8"}], "}"}]}], ",", 
        RowBox[{"ScalingFunctions", "->", 
         RowBox[{"{", 
          RowBox[{"\"\<Log\>\"", ",", "None"}], "}"}]}]}], "]"}]}], "}"}]}], ";", 
   RowBox[{"gRTlog", "=", 
    RowBox[{"Show", "[", 
     RowBox[{
      RowBox[{"Join", "[", 
       RowBox[{
        RowBox[{"{", "pltAnalyticLog", "}"}], ",", "pltNumLog"}], "]"}], ",", 
      
      RowBox[{"Frame", "->", "True"}], ",", 
      RowBox[{"Axes", "->", "False"}], ",", 
      RowBox[{"FrameLabel", "->", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"Style", "[", 
           RowBox[{"#", ",", "16"}], "]"}], "&"}], "/@", 
