Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"===", 
     RowBox[{"R", 
      RowBox[{"(", 
       RowBox[{"v", "^", "2"}], ")"}]}]}], ",", 
    RowBox[{
     RowBox[{"T", 
      RowBox[{"(", 
       RowBox[{"v", "^", "2"}], ")"}], " ", "con", " ", "eje", " ", "x", " ", 
      "logar\[IAcute]tmico"}], "==="}]}], "*)"}], 
  RowBox[{
   RowBox[{"pltAnalyticLog", "=", 
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{"Evaluate", "@", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"TanalyticV2", "[", "v2", "]"}], ",", 
         RowBox[{"RanalyticV2", "[", "v2", "]"}]}], "}"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"v2", ",", "v2Min", ",", "v2Max"}], "}"}], ",", 
      RowBox[{"PlotRange", "->", 
       RowBox[{"{", 
        RowBox[{"0", ",", "1"}], "}"}]}], ",", 
      RowBox[{"Exclusions", "->", "None"}], ",", 
      RowBox[{"PlotStyle", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Directive", "[", 
