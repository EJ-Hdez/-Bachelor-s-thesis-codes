          RowBox[{"\"\<\\!\\(\\*SuperscriptBox[\\(v\\), \\(2\\)]\\) (u.a., \
escala \\ log)\>\"", ",", "\"\<R, T\>\""}], "}"}]}], ")"}]}], ",", 
      RowBox[{"PlotRange", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"v2Min", ",", "v2Max"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"0", ",", "1"}], "}"}]}], "}"}]}], ",", 
      RowBox[{"ImageSize", "->", "700"}], ",", 
      RowBox[{"PlotRangePadding", "->", 
       RowBox[{"Scaled", "[", ".02", "]"}]}]}], "]"}]}], ";", 
   RowBox[{"pltRTsingleLog", "=", 
